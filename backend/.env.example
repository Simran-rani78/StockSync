PORT=5000
NODE_ENV=development

# Database Settings (PostgreSQL)
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASS=postgres
DB_NAME=stocksync_db
DB_SSL=false

# Authentication Settings
JWT_SECRET=supersecretjwtkeyforstocksyncsystem123!
JWT_EXPIRES_IN=7d

# AWS Cloud Credentials (for S3 File Uploads)
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=stocksync-product-images-bucket
